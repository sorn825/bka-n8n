# Secrets
.env

# Generated Excel output files
local-files/excel/*
!local-files/excel/.gitkeep

# Traefik TLS certificates (Let's Encrypt)
traefik_data/*
!traefik_data/.gitkeep

# Database backups — เก็บ .dump.enc ใน git แต่ไม่เก็บ .dump (unencrypted)
backup/*.dump
!backup/*.dump.enc

# Claude Code / Playwright MCP artifacts
.claude/
.playwright-mcp/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/

