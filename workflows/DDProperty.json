{
  "name": "DDProperty",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const baseUrl = \"https://www.ddproperty.com/รวมประกาศขาย\";\nconst source = \"DDProperty\";\nconst selector = \".search-result-root\";\n\nconst page_start = 1;\nconst page_stop = 5;\n\n// --------------------\n// Filters\n// --------------------\nconst regions = [\n  { name: \"กรุงเทพ\", code: \"TH10\" },\n  { name: \"นนทบุรี\", code: \"TH12\" }\n];\n\nconst propertyTypes = [\n  { group: \"B\", code: \"BUNG\", label: \"บ้านเดี่ยว\" },\n  { group: \"T\", code: \"TOWN\", label: \"ทาวน์เฮ้าส์\" },\n  { group: \"N\", code: \"CONDO\", label: \"คอนโด\" },\n  { group: \"L\", code: \"LAND\", label: \"ที่ดิน\" }\n];\n\nconst items = [];\n\nfor (const region of regions) {\n  for (const property of propertyTypes) {\n\n    const baseQuery =\n      `listingType=sale` +\n      `&propertyTypeGroup=${property.group}` +\n      `&propertyTypeCode=${property.code}` +\n      `&isCommercial=false` +\n      `&regionCode=${region.code}` +\n      `&_freetextDisplay=${region.name}`;\n\n    for (let page = page_start; page <= page_stop; page++) {\n\n      const pagePart = page === 1\n        ? `?${baseQuery}`\n        : `/${page}?${baseQuery}`;\n\n      items.push({\n        url: `${baseUrl}${pagePart}`,\n        selector,\n        source,\n      });\n    }\n  }\n}\n\nreturn items;\n"
      },
