# Domain Configuration
# Top-level domain (e.g. example.com)
DOMAIN_NAME=example.com

# Subdomain for n8n (e.g. n8n → https://n8n.example.com)
SUBDOMAIN=n8n

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
GENERIC_TIMEZONE=Asia/Bangkok

# Email for Let's Encrypt TLS certificate
SSL_EMAIL=your-email@example.com

# PostgreSQL password
POSTGRES_PASSWORD=change_me_strong_password

# n8n Owner Account (auto-created on first start, no setup wizard)
N8N_OWNER_EMAIL=admin@example.com
N8N_OWNER_PASSWORD=change_me_strong_password
N8N_OWNER_FIRSTNAME=Admin
N8N_OWNER_LASTNAME=User
